<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Темная тема -->
    <style name="Theme.MobileBookingApp" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary colors -->
        <item name="colorPrimary">@color/primary_dark_theme</item>
        <item name="colorPrimaryDark">@color/primary_dark_dark</item>
        <item name="colorAccent">@color/accent_dark</item>

        <!-- Backgrounds -->
        <item name="android:windowBackground">@color/background_dark</item>
